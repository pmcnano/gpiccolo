---
import type { Lang } from '../data/resume'
import { content } from '../data/resume'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = content[lang]
---

<section id="education">
  <div class="container">
    <p class="section-label">{t.sections.education}</p>
    {t.education.map((edu) => (
      <div class="edu-entry">
        <div class="edu-header">
          <div>
            <h3 class="edu-school">{edu.school}</h3>
            <p class="edu-degree muted">{edu.degree}</p>
          </div>
          <span class="mono muted edu-period">{edu.period}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .edu-school { font-size: 1rem; font-weight: 600; }
  .edu-degree { font-size: 0.875rem; margin-top: 0.15rem; }
  .edu-period { font-size: 0.8rem; }
</style>
